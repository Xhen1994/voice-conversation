# Voice Agent 配置文件
# 复制此文件为 .env 并填写你的配置

# Telegram 配置 (必需)
TELEGRAM_BOT_TOKEN=你的机器人 Token
TELEGRAM_CHAT_ID=你的 Chat ID

# OpenClaw 配置 (必需)
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=18789
OPENCLAW_TOKEN=你的 OpenClaw Token

# 模型配置 (可选)
VOICE_AGENT_MODEL=qwen/qwen3.5-plus

# Edge TTS 语音配置 (可选)
EDGE_VOICE=zh-CN-XiaoxiaoNeural

# 音频存储目录 (可选)
AUDIO_DIR=/home/xhen/.openclaw/media/voice
